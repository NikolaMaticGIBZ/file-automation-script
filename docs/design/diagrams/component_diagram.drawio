        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\nskinparam backgroundColor transparent\nskinparam shadowing false\nskinparam componentStyle rectangle\n\ntitle Automated Download Organizer - Component Diagram\n\npackage \&quot;Python Application\&quot; {\n\n    [main.py] as MAIN\n    [detector.py] as DETECTOR\n    [parser.py] as PARSER\n    [logger.py] as LOGGER\n    [config.py] as CONFIG\n\n}\n\npackage \&quot;Configuration\&quot; {\n\n    file \&quot;.env\&quot; as ENV\n    file \&quot;module_mapping.json\&quot; as JSON\n\n}\npackage \&quot;Discord\&quot; {\n    file \&quot;chatbot\&quot; as rpt\n}\n\npackage \&quot;Filesystem\&quot; {\n\n    folder \&quot;Downloads folder\&quot; as DOWNLOADS\n    folder \&quot;Module folders\&quot; as MODULES\n    folder \&quot;Unknown files folder\&quot; as UNKNOWN\n    folder \&quot;Logs folder\&quot; as LOGS\n\n}\n\nMAIN --&gt; CONFIG : Loads configuration\nMAIN --&gt; LOGGER : Initializes logging\nMAIN --&gt; DETECTOR : Starts file detection\nMAIN --&gt; PARSER : Requests filename parsing\n\nCONFIG --&gt; ENV : Reads environment variables\nCONFIG --&gt; JSON : Loads module mapping\n\nDETECTOR --&gt; DOWNLOADS : Scans files\n\nPARSER --&gt; CONFIG : Validates modules\n\nMAIN --&gt; MODULES : Moves valid files\nMAIN --&gt; UNKNOWN : Moves unsupported files\n\nLOGGER --&gt; LOGS : Writes log entries\nLOGS --&gt; rpt : Report summary to user\n\nMAIN --&gt; LOGGER : Logs runtime events\nDETECTOR --&gt; LOGGER : Logs detection events\nPARSER --&gt; LOGGER : Logs parsing warnings/errors\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Ddra5H0ihdwaCC-g8JNs-1">
