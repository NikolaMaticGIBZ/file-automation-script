        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nskinparam backgroundColor transparent\nskinparam shadowing false\n\ntitle Automated Download Organizer - Activity Diagram\n\nstart\n\n:Start Python Application;\n\n:Load Environment Variables;\n:Load Module Mapping Configuration;\n:Initialize Logging System;\n\nif (Configuration Valid?) then (yes)\n\n    :Scan Downloads Folder;\n\n    if (Files Found?) then (yes)\n\n        while (More Files Available?) is (yes)\n\n            :Read Filename;\n\n            :Validate Filename Structure;\n\n            if (Valid Module Pattern?) then (yes)\n\n                :Extract Module Identifier;\n\n                :Resolve Target Folder;\n\n                if (Target Folder Exists?) then (yes)\n                else (no)\n                    :Create Missing Folder;\n                    :Log Folder Creation;\n                endif\n\n                :Check Duplicate Filename;\n\n                if (Duplicate Exists?) then (yes)\n                    :Generate Safe Filename;\n                    :Log Duplicate Handling;\n                else (no)\n                endif\n\n                :Move File To Target Folder;\n\n                if (Move Successful?) then (yes)\n                    :Log Successful File Move;\n                else (no)\n\n                    :Log File Move Error;\n\n                endif\n\n            else (no)\n\n                :Log Invalid Filename Warning;\n\n            endif\n\n        endwhile (no)\n\n        :Log Processing Summary;\n\n    else (no)\n\n        :Log No Files Found;\n\n    endif\n\nelse (no)\n\n    :Log Configuration Error;\n\nendif\n\n:Close Logging System;\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2CCtsxaztpT9GkOugg-U-2">
